# ========== 功能开关 ==========

CACHE = {
    "enabled": True,              # 是否启用缓存
    "cache_dir": "cache",         # 缓存目录
    "cache_ttl": 3600,            # 缓存有效期（秒）
    "allow_duplicate": True,      # True=相同问题使用缓存，False=忽略缓存重新请求
}

